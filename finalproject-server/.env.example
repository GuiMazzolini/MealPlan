# Server port (default: 5005)
PORT=5005

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/MealPlan

# Secret used to sign JWT tokens — use a long random string in production
TOKEN_SECRET=replace-with-a-long-random-secret

# Frontend URL for CORS (no trailing slash)
CLIENT_URL=http://localhost:3000

# Cloudinary credentials (required for recipe image uploads)
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret
